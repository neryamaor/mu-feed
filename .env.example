# Supabase
# Note: Expo requires the EXPO_PUBLIC_ prefix to expose variables to the client bundle.
# These correspond to SUPABASE_URL and SUPABASE_ANON_KEY from ARCHITECTURE.md.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mux (server-side only — used in Supabase Edge Functions for video upload)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Transcription (server-side only)
WHISPER_API_KEY=

# Translation — Claude or GPT-4 (server-side only)
TRANSLATION_API_KEY=
TRANSLATION_API_PROVIDER=   # "claude" or "openai"
